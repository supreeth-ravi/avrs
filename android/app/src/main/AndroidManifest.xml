<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Core permissions -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Programmatically dial USSD for call forwarding setup -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.AVRSScreener"
        android:supportsRtl="true">

        <!-- Main onboarding activity -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Transparent overlay activity shown during live screening -->
        <activity
            android:name=".ui.ScreeningOverlayActivity"
            android:exported="false"
            android:theme="@style/Theme.AVRSScreener.Overlay"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true" />

        <!-- CallScreeningService — detects unknown incoming calls locally -->
        <service
            android:name=".ScreenerService"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>

        <!-- Foreground service maintaining WebSocket to AVRS backend -->
        <service
            android:name=".ScreeningWebSocketService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>
