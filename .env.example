# Copy this file to .env and fill in your values

# Required — Anthropic API key for the LLM agent
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Deepgram API key for fast cloud STT (~200ms)
# Leave unset to use local Whisper STT (offline, no API cost, ~4-8s on CPU)
DEEPGRAM_API_KEY=

# TTS engine: kokoro | mock  (default: kokoro)
# Use mock for development/testing without model files
AVRS_TTS_MODEL=kokoro

# LLM model override (default: claude-haiku-4-5-20251001)
# Use a larger model for better slot format compliance
AVRS_LLM_MODEL=claude-haiku-4-5-20251001

# Optional — API auth key to secure endpoints (leave empty for local dev)
AVRS_API_KEY=
